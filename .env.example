# Follow the Coast — Environment Variables
# Copy this file to .env and fill in values.

# Base URL for the backend API (leave empty if running locally on same origin)
VITE_API_BASE_URL=

# Payment provider (Stripe)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Analytics (optional)
# VITE_ANALYTICS_ID=

# Sanity CMS
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production
# VITE_SANITY_TOKEN=   # Only needed for draft previews
